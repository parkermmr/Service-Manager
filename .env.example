##########################################
# ENVIRONMENT CONFIGURATION
##########################################
# Copy this file to .env and customise for your environment
# All values shown are defaults - uncomment and change as needed

##########################################
# REGISTRY CONFIGURATION
##########################################

# Source registry used to pull the ubuntu base image during docker build
# For air-gapped or corporate environments, point this to your internal mirror
# Examples: docker.io | myregistry.com | harbor.internal.com
REGISTRY=docker.io

# Target registry used to tag and push built images
# Defaults to localhost for local development (no push required)
# Uncomment and set for remote registries
# Examples: docker.io/myuser | harbor.internal.com/myteam
PUSH_REGISTRY=localhost

##########################################
# IMAGE TAG
##########################################

# Base semantic version for the built image
# The final image tag will have plugin suffixes appended automatically by build.sh
# e.g. v1.0.0 -> v1.0.0-ansible-prometheus depending on plugins enabled
IMAGE_TAG=v1.0.0

##########################################
# USER CONFIGURATION
##########################################

# Non-root user created inside the container
# Should match the UID/GID of the user on the host to avoid volume permission issues
USER=somebody
USER_UID=1000
USER_GID=1000

##########################################
# NETWORK CONFIGURATION
##########################################

# GitHub mirror for downloading binaries during image build
# Override for air-gapped environments or to use a faster regional mirror
# Examples: https://github.com | https://github.mycompany.com
GITHUB_MIRROR=https://github.com

##########################################
# PLUGIN TOGGLES
##########################################

# Bake Ansible into the image at build time
# When true, ansible.sh runs during docker build as the non-root user
# Appends '-ansible' to the image tag
# Default: false
INSTALL_ANSIBLE=false

# Bake Prometheus stack into the image at build time
# When true, prometheus.sh runs during docker build as the non-root user
# Installs: prometheus, node_exporter, process_exporter
# Appends '-prometheus' to the image tag
# Default: false
INSTALL_PROMETHEUS=false