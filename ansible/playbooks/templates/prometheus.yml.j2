# Prometheus Configuration for {{ inventory_hostname }}
global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: 'node-cluster'
    environment: 'production'
    instance: '{{ inventory_hostname }}'
    node_id: '{{ node_id }}'

scrape_configs:
  # Prometheus self-monitoring
  - job_name: 'prometheus'
    scheme: https
    tls_config:
      ca_file: {{ prometheus_certs_dir }}/ca.crt
      cert_file: {{ prometheus_certs_dir }}/client.crt
      key_file: {{ prometheus_certs_dir }}/client.key
      # Optionally pin the server name if using a shared cert:
      # server_name: prometheus.local
    basic_auth:
      username: '{{ prometheus_scrape_user }}'
      password: '{{ prometheus_scrape_password }}'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          instance: '{{ inventory_hostname }}'

  # Node Exporter - system metrics (localhost only)
  - job_name: 'node-exporter'
    scheme: https
    tls_config:
      ca_file: {{ prometheus_certs_dir }}/ca.crt
      cert_file: {{ prometheus_certs_dir }}/client.crt
      key_file: {{ prometheus_certs_dir }}/client.key
    basic_auth:
      username: '{{ prometheus_scrape_user }}'
      password: '{{ prometheus_scrape_password }}'
    static_configs:
      - targets: ['localhost:9100']
        labels:
          instance: '{{ inventory_hostname }}'
          hostname: '{{ hostname }}'

  # Process Exporter - process metrics (localhost only)
  - job_name: 'process-exporter'
    scheme: https
    tls_config:
      ca_file: {{ prometheus_certs_dir }}/ca.crt
      cert_file: {{ prometheus_certs_dir }}/client.crt
      key_file: {{ prometheus_certs_dir }}/client.key
    basic_auth:
      username: '{{ prometheus_scrape_user }}'
      password: '{{ prometheus_scrape_password }}'
    static_configs:
      - targets: ['localhost:9256']
        labels:
          instance: '{{ inventory_hostname }}'
          hostname: '{{ hostname }}'